# ==========================================
# Architect-JS — .gitignore
# ==========================================

# Environment
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# TypeScript build output
packages/*/dist/

# Logs
logs/*.log
logs/failures/

# Dataset outputs (large, generated files)
datasets/v1_synthetic/*.jsonl
datasets/v2_mined/*.json
datasets/v3_hybrid/*.jsonl

# ChromaDB persistent store
data/rag_db/

# ML Models
models/
*.gguf
*.ggml
*.bin
*.safetensors

# Training outputs
outputs/
runs/
checkpoints/

# Jupyter
.ipynb_checkpoints/
*.ipynb~

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Temp files
*.tmp
*.temp
