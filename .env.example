# =========================================================
# Architect-JS — Environment Configuration Template
# Copy this file to .env and fill in your values.
# =========================================================

# -------------------------
# LLM Inference Server
# -------------------------
# URL of the local llama.cpp server (no trailing slash)
LLAMA_SERVER_URL=http://localhost:8080
LLAMA_SERVER_PORT=8080

# Model path for llama-server (used in startup scripts)
LLAMA_MODEL_PATH=models/architect-js-1.5b-unsloth.Q4_K_M.gguf

# Temperature for inference (low = deterministic, 0.1 recommended)
LLAMA_TEMPERATURE=0.1

# Max tokens to predict per completion
LLAMA_MAX_TOKENS=512

# Context window size (keep ≤ 2048 for RTX 3050 4GB)
LLAMA_CONTEXT_SIZE=2048

# -------------------------
# RAG Pipeline
# -------------------------
# Name of the ChromaDB collection for codebase indexing
RAG_COLLECTION_NAME=architect_js_codebase

# Persistent storage path for the ChromaDB vector database
RAG_DB_PATH=./data/rag_db

# Embedding model (local, no API key needed)
# Options: all-MiniLM-L6-v2 (fast, 80MB), all-mpnet-base-v2 (better, 420MB)
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Number of context chunks to retrieve per query
RAG_TOP_K=5

# Chunk size in tokens for document ingestion
RAG_CHUNK_SIZE=512

# Overlap between chunks (prevents context loss at boundaries)
RAG_CHUNK_OVERLAP=50

# -------------------------
# Data Mining (Optional)
# -------------------------
# GitHub Personal Access Token (for higher API rate limits during mining)
# Only needed for github_scraper.py
GITHUB_TOKEN=

# HuggingFace token (for gated models, not required for Qwen)
HF_TOKEN=

# -------------------------
# Logging
# -------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to log file
LOG_FILE=./logs/architect_js.log

# If true, full prompts and LLM responses are written to the log file
LOG_FULL_PROMPTS=false

# -------------------------
# Dataset Paths
# -------------------------
DATA_DIR=./data
DATASETS_DIR=./datasets
TRAIN_FILE=./data/train.jsonl
MANUAL_FIXES_FILE=./data/manual_fixes.json
UNSEEN_TEST_FILE=./data/unseen_test.json
